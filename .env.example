# ============================================================
# BABUU PLATFORM - Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Cohere (for embeddings)
COHERE_API_KEY=your-cohere-api-key

# Resend (for email reports)
RESEND_API_KEY=your-resend-api-key

# Cron security
CRON_SECRET=a-long-random-secret-string

# Google APIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Video processing
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
SHOTSTACK_API_KEY=your-shotstack-api-key

# SEO Tools
SEMRUSH_API_KEY=your-semrush-api-key
PROFOUND_API_KEY=your-profound-api-key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=a-long-random-secret-for-sessions

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Babuu
